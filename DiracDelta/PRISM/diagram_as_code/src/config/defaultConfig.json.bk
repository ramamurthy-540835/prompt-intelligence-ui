    },
    {
      "id": "mistral",
      "name": "Mistral 7B",
      "endpoint": "http://10.100.15.67:12143/v1/chat/completions",
      "description": "Balanced performance model"
    },
    {
      "id": "codellama",
      "name": "Code Llama",
      "endpoint": "http://10.100.15.67:12142/v1/chat/completions",
